# ============================================================
#  Paris Travel Planner Agent — Environment Variables Template
# ============================================================
#  INSTRUCTIONS:
#  1. Copy this file and rename it to .env
#  2. Fill in your actual API keys after each equals sign
#  3. NEVER commit the real .env file to version control
#
#  The agent uses a multi-model fallback chain.
#  At least ONE API key must be provided for the agent to run.
#  Priority order: OpenCode → Groq → Gemini → Google
# ============================================================

# ── Primary LLM: OpenCode (gpt-5.5 / claude-opus-4-7 via OpenCode router) ──
# Get your key at: https://opencode.ai
OPENCODE_API_KEY=

# ── Fallback 1: Groq (llama-3.3-70b-versatile) ─────────────────────────────
# Free tier available at: https://console.groq.com
# Note: Free tier is capped at 100,000 tokens/day
GROQ_API_KEY=

# ── Fallback 2: Gemini 2.0 Flash ────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Fallback 3: Google Gemini 1.5 Pro ───────────────────────────────────────
# Uses the same key family as GEMINI_API_KEY (Google AI Studio)
GOOGLE_API_KEY=
